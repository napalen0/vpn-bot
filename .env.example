# Copy to .env and fill in your values.
# Backend reads both vpn-bot/.env and vpn-bot/backend/.env (root .env wins on overlap).

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/vpn_bot.db

# ── Security ──────────────────────────────────────────────
API_SECRET=change-me-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Used to encrypt SSH passwords stored in DB. Do NOT change after servers are added.
SESSION_SECRET=change-me-another-random-string

# ── Telegram Bot ──────────────────────────────────────────
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_TELEGRAM_IDS=123456789
BACKEND_URL=http://127.0.0.1:8080

# ── Public URL (subscription links, CryptoPay webhooks) ──
PUBLIC_BASE_URL=https://vpn.example.com

# ── CryptoPay ─────────────────────────────────────────────
CRYPTOBOT_TOKEN=123456:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SKIP_WEBHOOK_SIGNATURE=false

# ── Background tasks ─────────────────────────────────────
SERVER_MONITOR_INTERVAL_SEC=300
SUBSCRIPTION_NOTIFY_INTERVAL_SEC=3600

# ── Xray SSH sync (auto-push UUIDs to servers) ───────────
# Option A: SSH key (recommended)
XRAY_SYNC_SSH_PRIVATE_KEY_PATH=
# Option B: password (less secure, fallback)
XRAY_SYNC_SSH_PASSWORD=

# ── Bot UI ────────────────────────────────────────────────
MAIN_MENU_IMAGE=menu_banner.png
REQUIRE_CHANNEL_SUBSCRIPTION=false
REQUIRED_CHANNEL_USERNAME=yourchannel
CHANNEL_PUBLIC_URL=https://t.me/yourchannel
